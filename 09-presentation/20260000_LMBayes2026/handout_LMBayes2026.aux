\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Effect of perceptual blur $w_f$ on communicative success (simulation, marginalised over all other parameters). Higher $w_f$ degrades the informativeness of size, reducing the advantage of \textsf  {big blue} over \textsf  {blue big}. The incremental speaker shows a larger separation between orderings than the global speaker.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:sim-wf}{{2}{3}{Effect of perceptual blur $w_f$ on communicative success (simulation, marginalised over all other parameters). Higher $w_f$ degrades the informativeness of size, reducing the advantage of \utter {big blue} over \utter {blue big}. The incremental speaker shows a larger separation between orderings than the global speaker}{figure.2}{}}
\newlabel{fig:sim-wf@cref}{{[figure][2][]2}{[1][2][]3}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Effect of colour semantic value $\nu $ on communicative success (simulation, marginalised over all other parameters). Higher $\nu $ (more deterministic colour semantics) increases \textsf  {blue big} success, narrowing the gap. The incremental speaker still favours size-first ordering across all $\nu $ values tested.}}{3}{figure.3}\protected@file@percent }
\newlabel{fig:sim-csv}{{3}{3}{Effect of colour semantic value $\nu $ on communicative success (simulation, marginalised over all other parameters). Higher $\nu $ (more deterministic colour semantics) increases \utter {blue big} success, narrowing the gap. The incremental speaker still favours size-first ordering across all $\nu $ values tested}{figure.3}{}}
