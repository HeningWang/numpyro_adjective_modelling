\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Effect of threshold $k$ on communicative success (simulation, marginalised over all other parameters). Lower $k$ (stricter threshold) reduces both orderings' success but narrows the gap between them. The incremental speaker maintains a consistent size-first advantage across $k$ values.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:sim-k}{{1}{2}{Effect of threshold $k$ on communicative success (simulation, marginalised over all other parameters). Lower $k$ (stricter threshold) reduces both orderings' success but narrows the gap between them. The incremental speaker maintains a consistent size-first advantage across $k$ values}{figure.1}{}}
\newlabel{fig:sim-k@cref}{{[figure][1][]1}{[1][2][]2}}
