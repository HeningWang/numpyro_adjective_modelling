\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Size-first advantage (\texttt  {big blue} $-$ \texttt  {blue big}) as a function of context size $n_\text  {obj}$ and context sharpness $\sigma _\text  {spread}$, faceted by speaker type. Both speakers show a positive advantage in sharp contexts that diminishes with increasing context size. Crucially, the incremental speaker exhibits a \emph  {negative} advantage (colour-first preference) in blurred contexts with few objects, a pattern absent from the global speaker.}}{13}{figure.9}\protected@file@percent }
\newlabel{fig:sim-nobj}{{9}{13}{Size-first advantage (\texttt {big blue} $-$ \texttt {blue big}) as a function of context size $n_\text {obj}$ and context sharpness $\sigma _\text {spread}$, faceted by speaker type. Both speakers show a positive advantage in sharp contexts that diminishes with increasing context size. Crucially, the incremental speaker exhibits a \emph {negative} advantage (colour-first preference) in blurred contexts with few objects, a pattern absent from the global speaker}{figure.9}{}}
\newlabel{fig:sim-nobj@cref}{{[figure][9][]9}{[1][12][]13}}
