\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Left: Observed vs.\ predicted utterance-type proportions (per condition $\times $ utterance type) for the incremental hierarchical model, with $R^2$ annotation and 95\% CIs. Right: LOO-ELPD comparison across four model variants; $|\Delta \text  {elpd}|/\text  {dse} = 4.6$ (strong evidence for the incremental hierarchical model).}}{12}{figure.8}\protected@file@percent }
\newlabel{fig:production-model}{{8}{12}{Left: Observed vs.\ predicted utterance-type proportions (per condition $\times $ utterance type) for the incremental hierarchical model, with $R^2$ annotation and 95\% CIs. Right: LOO-ELPD comparison across four model variants; $|\Delta \text {elpd}|/\text {dse} = 4.6$ (strong evidence for the incremental hierarchical model)}{figure.8}{}}
