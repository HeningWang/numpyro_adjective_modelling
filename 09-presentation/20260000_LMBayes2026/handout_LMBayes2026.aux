\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}Slider-rating study (Experiment 1)}{7}{subsection.2.1}\protected@file@percent }
\newlabel{sec:exp:slider}{{2.1}{7}{Slider-rating study (Experiment 1)}{subsection.2.1}{}}
\newlabel{sec:exp:slider@cref}{{[subsection][1][2]2.1}{[1][7][]7}}
\@writefile{toc}{\contentsline {paragraph}{Task.}{7}{section*.6}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Dependent variable.}{7}{section*.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Slider-rating empirical results. Mean centred slider ratings (0 = no preference) by relevant-property condition and sharpness, with 95\% CIs. Size-first orderings are preferred across all conditions, but the preference is strongest in size-relevant contexts and weakest in colour-relevant contexts. Sharpness modulates the size-first advantage asymmetrically across relevance conditions.}}{8}{figure.5}\protected@file@percent }
\newlabel{fig:slider-empirical}{{5}{8}{Slider-rating empirical results. Mean centred slider ratings (0 = no preference) by relevant-property condition and sharpness, with 95\% CIs. Size-first orderings are preferred across all conditions, but the preference is strongest in size-relevant contexts and weakest in colour-relevant contexts. Sharpness modulates the size-first advantage asymmetrically across relevance conditions}{figure.5}{}}
\newlabel{fig:slider-empirical@cref}{{[figure][5][]5}{[1][8][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Left: Condition-level observed vs.\ predicted mean slider ratings for the incremental hierarchical model, with $R^2$ annotation and 95\% CIs. Right: LOO-ELPD comparison across four model variants (best model highlighted in blue); $|\Delta \text  {elpd}|/\text  {dse} = 6.7$ (strong evidence for the incremental hierarchical model).}}{8}{figure.6}\protected@file@percent }
\newlabel{fig:slider-model}{{6}{8}{Left: Condition-level observed vs.\ predicted mean slider ratings for the incremental hierarchical model, with $R^2$ annotation and 95\% CIs. Right: LOO-ELPD comparison across four model variants (best model highlighted in blue); $|\Delta \text {elpd}|/\text {dse} = 6.7$ (strong evidence for the incremental hierarchical model)}{figure.6}{}}
\newlabel{fig:slider-model@cref}{{[figure][6][]6}{[1][8][]8}}
