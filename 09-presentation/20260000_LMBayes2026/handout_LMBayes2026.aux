\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Production empirical results. Utterance-type proportions (with bootstrapped 95\% CIs) by relevant-property condition and sharpness. Size-first orderings dominate in size-relevant contexts; colour-first orderings dominate in colour-relevant contexts. Only utterance types with $\geq 2\%$ in at least one condition are shown.}}{9}{figure.7}\protected@file@percent }
\newlabel{fig:production-empirical}{{7}{9}{Production empirical results. Utterance-type proportions (with bootstrapped 95\% CIs) by relevant-property condition and sharpness. Size-first orderings dominate in size-relevant contexts; colour-first orderings dominate in colour-relevant contexts. Only utterance types with $\geq 2\%$ in at least one condition are shown}{figure.7}{}}
\newlabel{fig:production-empirical@cref}{{[figure][7][]7}{[1][9][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Left: Observed vs.\ predicted utterance-type proportions (per condition $\times $ utterance type) for the incremental hierarchical model, with $R^2$ annotation and 95\% CIs. Right: LOO-ELPD comparison across four model variants; $|\Delta \text  {elpd}|/\text  {dse} = 4.6$ (strong evidence for the incremental hierarchical model).}}{10}{figure.8}\protected@file@percent }
\newlabel{fig:production-model}{{8}{10}{Left: Observed vs.\ predicted utterance-type proportions (per condition $\times $ utterance type) for the incremental hierarchical model, with $R^2$ annotation and 95\% CIs. Right: LOO-ELPD comparison across four model variants; $|\Delta \text {elpd}|/\text {dse} = 4.6$ (strong evidence for the incremental hierarchical model)}{figure.8}{}}
\newlabel{fig:production-model@cref}{{[figure][8][]8}{[1][9][]10}}
